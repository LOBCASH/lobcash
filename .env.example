# BSC chain config
POOL_PRIVATE_KEY=0xyour_private_key_here
TOKEN_ADDRESS=0xyour_token_address_here
BSC_RPC=https://bsc-dataseed.binance.org
TOKEN_DECIMALS=18

# Service ports and runtime
API_PORT=19200
PORT=19100
NODE_ENV=production

# Service-to-service URLs
API_URL=http://localhost:19200
GAME_SERVER_URL=ws://localhost:19100

# Browser-facing game URL returned by backend-api
GAME_SERVER_PUBLIC_WS_URL=ws://your-public-game-server

# Bot runner defaults
BOT_COUNT=5
BOT_STRATEGY=mixed
BOT_NAME=LobBot
BOT_API_KEY=dev-key

# Admin
ADMIN_KEY=change-this-to-a-strong-secret

# Frontend
NEXT_PUBLIC_API_URL=http://your-server-ip:19200
NEXT_PUBLIC_WS_URL=ws://your-server-ip:19100
