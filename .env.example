# ─── BSC Chain Config ───
# 热钱包私钥（存着代币，用来自动分发奖励）
POOL_PRIVATE_KEY=0xyour_private_key_here

# BEP-20 代币合约地址
TOKEN_ADDRESS=0xyour_token_address_here

# BSC RPC (主网/测试网)
# 主网: https://bsc-dataseed.binance.org
# 测试网: https://data-seed-prebsc-1-s1.binance.org:8545
BSC_RPC=https://bsc-dataseed.binance.org

# 代币精度（一般是 18）
TOKEN_DECIMALS=18

# ─── Server Config ───
API_PORT=19200
PORT=19100
NODE_ENV=production

# ─── Admin ───
ADMIN_KEY=change-this-to-a-strong-secret

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://your-server-ip:19200
NEXT_PUBLIC_WS_URL=ws://your-server-ip:19100
